<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!--
	    NSHealthShareUsageDescription — required by Apple for any app that calls
	    requestAuthorization(toShare:read:). Without this key the app will crash
	    immediately when the authorization sheet is triggered, regardless of the
	    toShare value passed.

	    NSHealthUpdateUsageDescription — required if the app ever writes to
	    HealthKit. InnuirBP is read-only, but the key must still be present
	    because the HealthKit capability is enabled in the entitlements file.
	    Omitting it can cause App Store review rejection.
	-->
	<key>NSHealthShareUsageDescription</key>
	<string>Innuir BP needs access to your blood pressure data to display your readings and sync them across your devices.</string>
	<key>NSHealthUpdateUsageDescription</key>
	<string>Innuir BP does not write to Health. Manual entries are stored only in the app.</string>
</dict>
</plist>
